// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mysql"
    url      = env("DATABASE_URL")
    relationMode = "prisma"
}

model Sport {
  	id    Int     @id @default(autoincrement())
  	name  String  @unique
  	games Game[]
}

model Game {
  	id      Int      @id @default(autoincrement())
  	sportId Int
  	sport   Sport    @relation(fields: [sportId], references: [id])
	ended   Boolean  @default(false)
	totalVolume Decimal
  	date    DateTime
	name    String	
  	teamA   String
  	teamB   String
  	markets Market[]

	@@index([sportId])
}

model Market {
  	id      Int      @id @default(autoincrement())
  	gameId  Int
  	game    Game     @relation(fields: [gameId], references: [id])
  	name    String
  	odds    Decimal

	@@index([gameId])
}

model Bet {
	id        Int      @id @default(autoincrement())
	userId    String
	user      User     @relation(fields: [userId], references: [address])
	gameId    Int
	marketId  Int
	amount    Decimal
	odds      Decimal
	profit    Decimal
	createdAt DateTime @default(now())

	@@index([userId])
	@@index([gameId])
	@@index([marketId])
}

model User {
	address String @id
	betHistory Bet[]

	@@index([address])
}

model Carousel {
    id    Int            @id @default(autoincrement())  // Unique identifier for Carousel
    items CarouselItem[]
}

model CarouselItem {
    id       Int    @id @default(autoincrement())  // Unique identifier for CarouselItem
    imageLink String
    href     String
    carouselId Int      // To establish a relation between Carousel and CarouselItem
    carousel  Carousel @relation(fields: [carouselId], references: [id])

    @@index([carouselId])
}

model apyHistory {
	date   DateTime @id
	apy    Decimal
}