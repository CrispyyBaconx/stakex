// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider        = "prisma-client-js"
    previewFeatures = ["driverAdapters"]
}

datasource db {
    provider = "mysql"
    url      = env("DATABASE_URL")

    // Do not use foreign keys (PlanetScale does not support them)
    relationMode = "prisma"
}

model Sport {
  	id    Int     @id @default(autoincrement())
  	name  String  @unique
  	games Game[]
}

model Game {
  	id      Int      @id @default(autoincrement())
  	sportId Int
  	sport   Sport    @relation(fields: [sportId], references: [id])
	ended   Boolean  @default(false)
	totalVolume Decimal
  	date    DateTime
	name    String	
  	teamA   String
  	teamB   String
  	markets Market[]

	@@index([sportId])
}

model Market {
  	id      Int      @id @default(autoincrement())
  	gameId  Int
  	game    Game     @relation(fields: [gameId], references: [id])
  	name    String
  	odds    Decimal

	@@index([gameId])
}

model Bet {
	id        Int      @id @default(autoincrement())
	userId    String
	user      User     @relation(fields: [userId], references: [address])
	gameId    Int
	marketId  Int
	amount    Decimal
	odds      Decimal
	profit    Decimal
	createdAt DateTime @default(now())

	@@index([userId])
	@@index([gameId])
	@@index([marketId])
}

model User {
	address String @id
	betHistory Bet[]

	@@index([address])
}

model CarouselItem {
    id       Int    @id @default(autoincrement())
    imageLink String
    href     String

    @@index([id])
}

model Pool {
	id    Int     @id @default(autoincrement())
	name  String  @unique
	address String
}

model ApyHistory {
	date   DateTime @id
	apy    Decimal
}